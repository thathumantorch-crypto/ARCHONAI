{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "worker/src/**/*"
  ]
}
